@model LaundryMVC.Models.Register
@{ ViewData["Title"] = "Admin Register"; }
<!DOCTYPE html>
<html>
<head>
    <title>Admin Register</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * { box-sizing:border-box; margin:0; padding:0; }
        body {
            min-height:100vh; font-family:'Segoe UI',sans-serif;
            background:linear-gradient(135deg,#1a0000,#3d0000,#1a0a0a);
            position:relative; overflow-x:hidden;
        }
        body::before {
            content:''; position:fixed; width:450px; height:450px; border-radius:50%;
            background:radial-gradient(circle,rgba(239,68,68,0.3),transparent 70%);
            top:-80px; right:-80px; pointer-events:none;
        }
        body::after {
            content:''; position:fixed; width:380px; height:380px; border-radius:50%;
            background:radial-gradient(circle,rgba(99,102,241,0.2),transparent 70%);
            bottom:-60px; left:-60px; pointer-events:none;
        }
        nav {
            display:flex; align-items:center; justify-content:space-between;
            padding:0 32px; height:64px;
            background:rgba(255,255,255,0.04); backdrop-filter:blur(12px);
            border-bottom:1px solid rgba(255,255,255,0.08); position:relative; z-index:10;
        }
        .brand { display:flex; align-items:center; gap:10px; font-size:17px; font-weight:600; color:#fff; text-decoration:none; }
        .brand-dot {
            width:32px; height:32px; border-radius:10px;
            background:linear-gradient(135deg,#dc2626,#ef4444);
            display:flex; align-items:center; justify-content:center;
            box-shadow:0 0 16px rgba(239,68,68,0.6); font-size:16px; color:white;
        }
        .admin-badge { font-size:10px; padding:3px 10px; border-radius:12px; background:rgba(239,68,68,0.2); color:#fca5a5; border:1px solid rgba(239,68,68,0.3); }
        .page-wrap { display:flex; justify-content:center; padding:40px 20px; position:relative; z-index:2; }
        .glass-card {
            width:100%; max-width:460px;
            background:rgba(255,255,255,0.05);
            backdrop-filter:blur(20px);
            border-radius:24px;
            border:1px solid rgba(255,255,255,0.1);
            padding:36px 30px;
            box-shadow:0 8px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
        }
        .icon-ring {
            width:60px; height:60px; border-radius:18px;
            background:rgba(239,68,68,0.2); border:1px solid rgba(239,68,68,0.35);
            box-shadow:0 0 22px rgba(239,68,68,0.3);
            display:flex; align-items:center; justify-content:center;
            font-size:28px; color:#ef4444; margin:0 auto 18px;
        }
        h2 { font-size:22px; font-weight:600; text-align:center; color:#fff; margin-bottom:5px; }
        .sub { font-size:13px; text-align:center; color:rgba(255,255,255,0.45); margin-bottom:24px; }
        label { display:block; font-size:11px; font-weight:600; color:rgba(255,255,255,0.55); margin-bottom:6px; letter-spacing:0.5px; text-transform:uppercase; }
        .field { margin-bottom:14px; }
        .row2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
        input[type=text], input[type=email], input[type=password], textarea {
            width:100%; padding:11px 14px; font-size:14px;
            background:rgba(255,255,255,0.07);
            border:1px solid rgba(255,255,255,0.1);
            border-radius:10px; color:#fff; outline:none;
            transition:border-color 0.15s; font-family:inherit;
        }
        textarea { resize:none; }
        input::placeholder, textarea::placeholder { color:rgba(255,255,255,0.25); }
        input:focus, textarea:focus { border-color:rgba(239,68,68,0.6); background:rgba(255,255,255,0.1); }
        .submit-btn {
            width:100%; padding:13px; border-radius:12px; border:none;
            background:linear-gradient(135deg,#dc2626,#ef4444); color:#fff;
            font-size:15px; font-weight:600; cursor:pointer;
            box-shadow:0 4px 18px rgba(239,68,68,0.4);
            display:flex; align-items:center; justify-content:center; gap:8px;
            transition:transform 0.1s;
        }
        .submit-btn:active { transform:scale(0.98); }
        .error-text { color:#fca5a5; font-size:13px; text-align:center; margin-top:12px; }
    </style>
</head>
<body>
    <nav>
        <a class="brand">
            <div class="brand-dot"><i class="bi bi-basket2-fill"></i></div>
            Laundry Express
        </a>
        <div style="display:flex;align-items:center;gap:10px;">
            <span class="admin-badge">Admin Panel</span>
            <a href="javascript:history.back()" style="display:flex;align-items:center;gap:6px;font-size:13px;color:rgba(255,255,255,0.7);text-decoration:none;background:rgba(255,255,255,0.08);padding:8px 14px;border-radius:10px;border:1px solid rgba(255,255,255,0.12);transition:background 0.15s;">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </nav>
    <div class="page-wrap">
        <div class="glass-card">
            <div class="icon-ring"><i class="bi bi-person-gear"></i></div>
            <h2>Register admin</h2>
            <p class="sub">Create a new administrator account</p>
            <form asp-action="AdminRegister" method="post">
                <div class="row2">
                    <div class="field">
                        <label>Full name</label>
                        <input asp-for="Name" placeholder="Admin name" />
                    </div>
                    <div class="field">
                        <label>Mobile number</label>
                        <input asp-for="MobileNo" placeholder="9876543210" />
                    </div>
                </div>
                <div class="field">
                    <label>Email address</label>
                    <input asp-for="Email" placeholder="admin@example.com" />
                </div>
                <div class="field">
                    <label>Password</label>
                    <input asp-for="Password" type="password" placeholder="Create a strong password" />
                </div>
                <div class="field">
                    <label>Address</label>
                    <textarea asp-for="Address" rows="2" placeholder="Office or branch address..."></textarea>
                </div>
                <button type="submit" class="submit-btn">
                    <i class="bi bi-check-circle"></i> Register admin account
                </button>
            </form>
            @if (ViewBag.Error != null) {
                <p class="error-text">@ViewBag.Error</p>
            }
        </div>
    </div>
</body>
</html>