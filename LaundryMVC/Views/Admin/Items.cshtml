@model IEnumerable<LaundryMVC.Models.Item>

@{
    ViewData["Title"] = "Manage Items";
    int serial = 1;
}

<!DOCTYPE html>
<html>
<head>
    <title>Manage Items</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(135deg,#0f0c29,#302b63,#24243e);
            position: relative;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(99,102,241,0.25),transparent 70%);
                top: -100px;
                left: -100px;
                pointer-events: none;
            }

            body::after {
                content: '';
                position: fixed;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(16,185,129,0.15),transparent 70%);
                bottom: -80px;
                right: -80px;
                pointer-events: none;
            }

        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            height: 64px;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            position: relative;
            z-index: 10;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 17px;
            font-weight: 600;
            color: #fff;
            text-decoration: none;
        }

        .brand-dot {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 16px rgba(139,92,246,0.6);
            font-size: 16px;
            color: white;
        }

        .nav-badge {
            font-size: 10px;
            padding: 3px 10px;
            border-radius: 12px;
            background: rgba(99,102,241,0.2);
            color: #a5b4fc;
            border: 1px solid rgba(99,102,241,0.3);
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 36px 24px;
            position: relative;
            z-index: 2;
        }

        .page-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

            .page-head h2 {
                font-size: 22px;
                font-weight: 600;
                color: #fff;
            }

            .page-head p {
                font-size: 13px;
                color: rgba(255,255,255,0.45);
                margin-top: 3px;
            }

        .header-buttons {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .add-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            background: linear-gradient(135deg,#059669,#10b981);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 9px 18px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(16,185,129,0.35);
            transition: 0.2s;
        }

            .add-btn:hover {
                transform: translateY(-2px);
            }

        .back-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.85);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            padding: 9px 18px;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: 0.2s;
        }

            .back-btn:hover {
                background: rgba(255,255,255,0.14);
            }

        .glass-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(16px);
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.12);
            padding: 24px;
            box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        thead th {
            padding: 12px 16px;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        tbody tr {
            border-bottom: 1px solid rgba(255,255,255,0.06);
            transition: background 0.15s;
        }

            tbody tr:hover {
                background: rgba(255,255,255,0.04);
            }

            tbody tr:last-child {
                border-bottom: none;
            }

        td {
            padding: 13px 16px;
            font-size: 13px;
            color: rgba(255,255,255,0.85);
            vertical-align: middle;
        }

        .item-icon {
            width: 32px;
            height: 32px;
            border-radius: 9px;
            background: rgba(99,102,241,0.2);
            border: 1px solid rgba(99,102,241,0.3);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #a5b4fc;
            margin-right: 10px;
            vertical-align: middle;
        }

        .price-val {
            color: #6ee7b7;
            font-weight: 600;
        }

        .btn-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            transition: transform 0.1s;
            text-decoration: none;
        }

            .btn-icon:active {
                transform: scale(0.95);
            }

        .btn-edit {
            background: rgba(245,158,11,0.2);
            color: #fcd34d;
            border: 1px solid rgba(245,158,11,0.3);
        }

        .btn-delete {
            background: rgba(239,68,68,0.2);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.3);
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: rgba(255,255,255,0.35);
            font-size: 14px;
        }

    </style>

</head>

<body>

    <nav>

        <a class="brand">

            <div class="brand-dot">
                <i class="bi bi-basket2-fill"></i>
            </div>

            Laundry Express

        </a>

        <span class="nav-badge">
            Admin Panel
        </span>

    </nav>

    <div class="container">

        <div class="page-head">

            <div>

                <h2>
                    Manage Items
                </h2>

                <p>
                    Add, edit or remove laundry service items
                </p>

            </div>

            <div class="header-buttons">

                <!-- BACK BUTTON -->

                <a asp-action="Dashboard"
                   asp-controller="Admin"
                   class="back-btn">

                    <i class="bi bi-arrow-left"></i>

                    Back

                </a>

                <!-- ADD BUTTON -->

                <a asp-action="AddItem"
                   asp-controller="Admin"
                   class="add-btn">

                    <i class="bi bi-plus-circle"></i>

                    Add New Item

                </a>

            </div>

        </div>

        <div class="glass-card">

            <table>

                <thead>

                    <tr>

                        <th>#</th>
                        <th>Item Name</th>
                        <th>Price</th>
                        <th>Actions</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td style="color:rgba(255,255,255,0.4);">
                                    @serial
                                </td>

                                <td>

                                    <span class="item-icon">
                                        <i class="bi bi-basket"></i>
                                    </span>

                                    <span style="font-weight:500;">
                                        @item.ItemName
                                    </span>

                                </td>

                                <td class="price-val">
                                    ₹ @item.Price
                                </td>

                                <td>

                                    <a asp-action="EditItem"
                                       asp-route-id="@item.Id"
                                       class="btn-icon btn-edit"
                                       style="margin-right:6px;">

                                        <i class="bi bi-pencil-square"></i>

                                    </a>

                                    <a asp-action="DeleteItem"
                                       asp-route-id="@item.Id"
                                       class="btn-icon btn-delete"
                                       onclick="return confirm('Delete this item?')">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </td>

                            </tr>

                            serial++;
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="4">

                                <div class="empty-state">

                                    <i class="bi bi-basket"
                                       style="font-size:32px;display:block;margin-bottom:8px;"></i>

                                    No items found

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</body>
</html>