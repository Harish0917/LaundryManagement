@model List<LaundryMVC.Models.Register>
@{
    ViewData["Title"] = "Customer List";
    int serial = 1;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer List</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
        }

        /* NAV */
        .top-nav {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .brand-logo {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 16px rgba(139,92,246,0.6);
            font-size: 15px;
            color: #fff;
        }

        .brand-name {
            font-size: 17px;
            font-weight: 600;
            color: #fff;
        }

        .nav-pill {
            font-size: 10px;
            padding: 3px 12px;
            border-radius: 20px;
            background: rgba(99,102,241,0.2);
            color: #a5b4fc;
            border: 1px solid rgba(99,102,241,0.3);
            letter-spacing: 0.5px;
            font-weight: 600;
            text-transform: uppercase;
        }

        /* PAGE WRAPPER */
        .page-wrapper {
            max-width: 950px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* STAT CARDS */
        .stat-card {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            backdrop-filter: blur(10px);
            transition: transform 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-3px);
            }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .icon-indigo {
            background: rgba(99,102,241,0.2);
            color: #a5b4fc;
            border: 1px solid rgba(99,102,241,0.3);
        }

        .icon-green {
            background: rgba(16,185,129,0.2);
            color: #6ee7b7;
            border: 1px solid rgba(16,185,129,0.3);
        }

        .icon-red {
            background: rgba(239,68,68,0.2);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.3);
        }

        .stat-val {
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .stat-lbl {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 3px;
        }

        /* TABLE CARD */
        .table-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 20px;
            overflow: hidden;
            backdrop-filter: blur(16px);
            box-shadow: 0 8px 40px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.1);
        }

        .table-card-header {
            background: rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.09);
            padding: 16px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .table-card-header h5 {
                color: #fff;
                font-weight: 700;
                font-size: 15px;
                margin: 0;
            }

        .count-badge {
            font-size: 11px;
            padding: 4px 12px;
            border-radius: 20px;
            background: rgba(99,102,241,0.2);
            color: #a5b4fc;
            border: 1px solid rgba(99,102,241,0.3);
            font-weight: 600;
        }

        /* TABLE OVERRIDES */
        .custom-table {
            margin: 0;
            color: rgba(255,255,255,0.85);
        }

            .custom-table thead th {
                background: rgba(255,255,255,0.03);
                color: rgba(255,255,255,0.45);
                font-size: 10.5px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                border-color: rgba(255,255,255,0.09);
                padding: 13px 20px;
            }

            .custom-table tbody tr {
                border-color: rgba(255,255,255,0.06);
                transition: background 0.15s;
            }

                .custom-table tbody tr:hover {
                    background: rgba(255,255,255,0.04);
                    color: rgba(255,255,255,0.85);
                }

                .custom-table tbody tr:last-child td {
                    border-bottom: none;
                }

            .custom-table td {
                padding: 13px 20px;
                vertical-align: middle;
                border-color: rgba(255,255,255,0.06);
                background: transparent;
                color: rgba(255,255,255,0.82);
            }

        /* SERIAL */
        .serial-num {
            color: rgba(255,255,255,0.3);
            font-size: 12px;
            font-weight: 600;
        }

        /* AVATAR */
        .avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: rgba(99,102,241,0.3);
            border: 1px solid rgba(99,102,241,0.4);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: #a5b4fc;
            flex-shrink: 0;
        }

        .name-text {
            font-weight: 500;
            color: #fff;
        }

        .email-text {
            color: rgba(165,180,252,0.85);
            font-size: 13px;
        }

        /* ROLE PILLS */
        .role-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11px;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
        }

        .role-admin {
            background: rgba(239,68,68,0.2);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.3);
        }

        .role-customer {
            background: rgba(16,185,129,0.2);
            color: #6ee7b7;
            border: 1px solid rgba(16,185,129,0.3);
        }

        /* BACK BTN */
        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.08);
            color: rgba(255,255,255,0.75);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            padding: 8px 18px;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.15s;
        }

            .btn-back:hover {
                background: rgba(255,255,255,0.14);
                color: #fff;
            }

        /* EMPTY STATE */
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: rgba(255,255,255,0.35);
        }

            .empty-state i {
                font-size: 38px;
                display: block;
                margin-bottom: 10px;
            }

            .empty-state p {
                font-size: 14px;
                margin: 0;
            }
    </style>
</head>
<body>

    <!-- NAV -->
    <div class="top-nav">
        <div class="d-flex align-items-center gap-2">
            <div class="brand-logo"><i class="bi bi-basket2-fill"></i></div>
            <span class="brand-name">Laundry Express</span>
        </div>
        <span class="nav-pill">Admin Panel</span>
    </div>

    <div class="page-wrapper">

        <!-- PAGE HEADER -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon icon-indigo">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div>
                    <h4 class="text-white fw-bold mb-0">Customer List</h4>
                    <p class="mb-0" style="color:rgba(255,255,255,0.4); font-size:13px;">All registered users and admins</p>
                </div>
            </div>
            <a asp-action="Dashboard" asp-controller="Admin" class="btn-back">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>

        <!-- STAT CARDS -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-4">
                <div class="stat-card">
                    <div class="stat-icon icon-indigo"><i class="bi bi-people-fill"></i></div>
                    <div>
                        <div class="stat-val">@(Model?.Count ?? 0)</div>
                        <div class="stat-lbl">Total Users</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="stat-card">
                    <div class="stat-icon icon-green"><i class="bi bi-person-fill"></i></div>
                    <div>
                        <div class="stat-val">@(Model?.Count(c => c.role != "Admin") ?? 0)</div>
                        <div class="stat-lbl">Customers</div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="stat-card">
                    <div class="stat-icon icon-red"><i class="bi bi-shield-fill"></i></div>
                    <div>
                        <div class="stat-val">@(Model?.Count(c => c.role == "Admin") ?? 0)</div>
                        <div class="stat-lbl">Admins</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TABLE CARD -->
        <div class="table-card">
            <div class="table-card-header">
                <h5><i class="bi bi-list-ul me-2" style="color:#a5b4fc;"></i>User Records</h5>
                <span class="count-badge">@(Model?.Count ?? 0) Total</span>
            </div>
            <div class="table-responsive">
                <table class="table custom-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var c in Model)
                            {
                                <tr>
                                    <td><span class="serial-num">@serial</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="avatar">
                                                @(c.Name?.Length > 0 ? c.Name[0].ToString().ToUpper() : "?")
                                            </div>
                                            <span class="name-text">@c.Name</span>
                                        </div>
                                    </td>
                                    <td><span class="email-text">@c.Email</span></td>
                                    <td>
                                        @if (c.role == "Admin")
                                        {
                                            <span class="role-pill role-admin">
                                                <i class="bi bi-shield-fill" style="font-size:9px;"></i> Admin
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="role-pill role-customer">
                                                <i class="bi bi-person-fill" style="font-size:9px;"></i> Customer
                                            </span>
                                        }
                                    </td>
                                </tr>
                                serial++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4">
                                    <div class="empty-state">
                                        <i class="bi bi-people"></i>
                                        <p>No customers found</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
