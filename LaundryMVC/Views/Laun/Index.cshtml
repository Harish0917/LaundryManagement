@model List<LaundryMVC.Models.Item>

@{
    ViewData["Title"] = "Laundry Items";
}

<!DOCTYPE html>
<html>
<head>
    <title>Laundry Items</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(135deg,#0f0c29,#302b63,#24243e);
            position: relative;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                width: 450px;
                height: 450px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(99,102,241,0.3),transparent 70%);
                top: -80px;
                left: -80px;
                pointer-events: none;
            }

            body::after {
                content: '';
                position: fixed;
                width: 380px;
                height: 380px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(16,185,129,0.2),transparent 70%);
                bottom: -60px;
                right: -60px;
                pointer-events: none;
            }

        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            height: 64px;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.1);
            position: relative;
            z-index: 10;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 17px;
            font-weight: 600;
            color: #fff;
            text-decoration: none;
        }

        .brand-dot {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 16px rgba(139,92,246,0.6);
            font-size: 16px;
            color: white;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-orders {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            background: rgba(255,255,255,0.08);
            padding: 8px 14px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.12);
            transition: background 0.15s;
        }

            .nav-orders:hover {
                background: rgba(255,255,255,0.14);
            }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: white;
            background: linear-gradient(135deg,#dc2626,#ef4444);
            padding: 8px 14px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: 600;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 36px 20px 48px;
            position: relative;
            z-index: 2;
        }

        .page-head {
            text-align: center;
            margin-bottom: 28px;
        }

            .page-head h2 {
                font-size: 22px;
                font-weight: 600;
                color: #fff;
                margin-bottom: 6px;
            }

            .page-head p {
                font-size: 13px;
                color: rgba(255,255,255,0.45);
            }

        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px,1fr));
            gap: 12px;
            margin-bottom: 28px;
        }

        .item-card {
            background: rgba(255,255,255,0.07);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 16px;
            padding: 16px 12px;
            text-align: center;
            position: relative;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.12);
            transition: border-color 0.15s, transform 0.15s;
        }

            .item-card:hover {
                border-color: rgba(139,92,246,0.4);
                transform: translateY(-2px);
            }

        .item-chk {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 16px;
            height: 16px;
            accent-color: #8b5cf6;
            cursor: pointer;
        }

        .item-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(99,102,241,0.2);
            border: 1px solid rgba(99,102,241,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #a5b4fc;
            margin: 0 auto 10px;
        }

        .item-name {
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            margin-bottom: 4px;
        }

        .item-price {
            font-size: 13px;
            color: #6ee7b7;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .qty-input {
            width: 60px;
            padding: 6px 8px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            color: #fff;
            font-size: 13px;
            text-align: center;
            outline: none;
        }

            .qty-input:focus {
                border-color: rgba(99,102,241,0.6);
            }

        .submit-wrap {
            text-align: center;
        }

        .pickup-btn {
            background: linear-gradient(135deg,#059669,#10b981);
            color: #fff;
            border: none;
            border-radius: 13px;
            padding: 14px 36px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(16,185,129,0.45);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: transform 0.1s;
        }

            .pickup-btn:active {
                transform: scale(0.98);
            }

        footer {
            text-align: center;
            font-size: 12px;
            color: rgba(255,255,255,0.3);
            padding: 16px;
            border-top: 1px solid rgba(255,255,255,0.07);
            background: rgba(0,0,0,0.2);
            position: relative;
            z-index: 2;
        }

    </style>

</head>

<body>

    <nav>

        <a class="brand">

            <div class="brand-dot">
                <i class="bi bi-basket2-fill"></i>
            </div>

            Laundry Express

        </a>

        <div class="nav-right">

            <a asp-action="OrderHistory"
               asp-controller="Laun"
               class="nav-orders">

                <i class="bi bi-box-seam"></i>

                My Orders

            </a>

            <a href="javascript:history.back()"
               class="nav-orders">

                <i class="bi bi-arrow-left"></i>

                Back

            </a>

            <!-- LOGOUT BUTTON -->

            <button type="button"
                    class="logout-btn"
                    onclick="logoutConfirm()">

                <i class="bi bi-box-arrow-right"></i>

                Logout

            </button>

        </div>

    </nav>

    <div class="container">

        <div class="page-head">

            <h2>
                Select items to wash
            </h2>

            <p>
                Check items and set quantity, then schedule your pickup
            </p>

        </div>

        <form asp-action="AddMultipleOrders"
              method="post">

            <div class="items-grid">

                @for (int i = 0; i < Model.Count; i++)
                {
                    <div class="item-card">

                        <input type="checkbox"
                               name="selectedItems"
                               value="@Model[i].ItemName"
                               class="item-chk" />

                        <input type="hidden"
                               name="items[@i].ItemName"
                               value="@Model[i].ItemName" />

                        <input type="hidden"
                               name="items[@i].Price"
                               value="@Model[i].Price" />

                        <div class="item-icon">
                            <i class="bi bi-basket"></i>
                        </div>

                        <div class="item-name">
                            @Model[i].ItemName
                        </div>

                        <div class="item-price">
                            ₹ @Model[i].Price
                        </div>

                        <input type="number"
                               name="items[@i].Quantity"
                               value="1"
                               min="1"
                               class="qty-input" />

                    </div>
                }

            </div>

            <div class="submit-wrap">

                <button type="submit"
                        class="pickup-btn">

                    <i class="bi bi-truck"></i>

                    Schedule Pickup

                </button>

            </div>

        </form>

    </div>

    <footer>
        © 2026 Laundry Express — All Rights Reserved
    </footer>

    <script>

        function logoutConfirm() {

            let result = confirm("Are you sure you want to logout?");

            if (result) {

                window.location.href = '/Auth/CustomerLogin';

            }

        }

    </script>

</body>
</html>